# =============================================================================
# His.Hope EMR - Environment Variables (Local Development)
# SECURITY: NEVER commit the actual .env file. This is a template only.
# Copy this file to .env and fill in secure values before running docker-compose.
# =============================================================================

# === Database ===
# PostgreSQL superuser password - MUST be changed in production
POSTGRES_PASSWORD=ChangeMe_DB_Password_123!

# === Message Broker (RabbitMQ) ===
RABBITMQ_DEFAULT_USER=admin
RABBITMQ_DEFAULT_PASS=ChangeMe_RabbitMQ_123!

# === Monitoring ===
# Grafana admin password - MUST be changed in production
GF_SECURITY_ADMIN_PASSWORD=ChangeMe_Grafana_123!

# === TLS Certificates ===
# Password for .pfx certificate files
CERTIFICATE_PASSWORD=ChangeMe_Cert_Password_123!

# === CORS ===
# Comma-separated list of allowed origins for the API gateway
CORS_ALLOWED_ORIGINS=https://localhost:4200,https://his-hope.internal

# === JWT RSA Signing Keys ===
# In production, these come from Vault (transit engine or PKI).
# For local dev, generate RSA keys:
#   openssl genrsa -out jwt-private-key.pem 2048
#   openssl rsa -in jwt-private-key.pem -pubout -out jwt-public-key.pem
JWT_RSA_PRIVATE_KEY_PATH=Certificates/jwt-private-key.pem
JWT_RSA_PUBLIC_KEY_PATH=Certificates/jwt-public-key.pem

# === Database Connection (used by appsettings.json) ===
DB_PASSWORD=ChangeMe_DB_Password_123!

# === Vault (production only) ===
# VAULT_ADDR=https://vault.his-hope.internal:8200
# VAULT_ROLE_ID=
# VAULT_SECRET_ID=
