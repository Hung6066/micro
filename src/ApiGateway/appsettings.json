{
  "Serilog": {
    "MinimumLevel": { "Default": "Information" },
    "WriteTo": [{ "Name": "Console" }]
  },
  "ReverseProxy": {
    "Routes": {
      "identity": {
        "ClusterId": "identity",
        "Match": { "Path": "/api/v1/auth/{**catch-all}" }
      },
      "patients": {
        "ClusterId": "patients",
        "Match": { "Path": "/api/v1/patients/{**catch-all}" }
      },
      "appointments": {
        "ClusterId": "appointments",
        "Match": { "Path": "/api/v1/appointments/{**catch-all}" }
      },
      "clinical": {
        "ClusterId": "clinical",
        "Match": { "Path": "/api/v1/encounters/{**catch-all}" }
      }
    },
    "Clusters": {
      "identity": {
        "Destinations": {
          "identity/dest": { "Address": "https://identityservice:5001/" }
        }
      },
      "patients": {
        "Destinations": {
          "patients/dest": { "Address": "https://patientservice:5002/" }
        }
      },
      "appointments": {
        "Destinations": {
          "appointments/dest": { "Address": "https://appointmentservice:5003/" }
        }
      },
      "clinical": {
        "Destinations": {
          "clinical/dest": { "Address": "https://clinicalservice:5004/" }
        }
      }
    }
  },
  "Certificates": {
    "Path": "",
    "Password": ""
  }
}
