{
  "Serilog": {
    "MinimumLevel": { "Default": "Information" },
    "WriteTo": [{ "Name": "Console" }]
  },
  "ReverseProxy": {
    "Routes": {
      "identity": {
        "ClusterId": "identity",
        "Match": { "Path": "/api/v1/auth/{**catch-all}" }
      },
      "patient-encounters": {
        "ClusterId": "clinical",
        "Match": { "Path": "/api/v1/patients/{patientId}/encounters" }
      },
      "patient-appointments": {
        "ClusterId": "appointments",
        "Match": { "Path": "/api/v1/patients/{patientId}/appointments" }
      },
      "patient-lab-orders": {
        "ClusterId": "lab",
        "Match": { "Path": "/api/v1/patients/{patientId}/lab-orders" }
      },
      "patient-prescriptions": {
        "ClusterId": "pharmacy",
        "Match": { "Path": "/api/v1/patients/{patientId}/prescriptions" }
      },
      "patient-invoices": {
        "ClusterId": "billing",
        "Match": { "Path": "/api/v1/patients/{patientId}/invoices" }
      },
      "lab-critical-alerts-hub-root": {
        "ClusterId": "lab",
        "Match": { "Path": "/hubs/lab-critical-alerts" }
      },
      "lab-critical-alerts-hub": {
        "ClusterId": "lab",
        "Match": { "Path": "/hubs/lab-critical-alerts/{**catch-all}" }
      },
      "patients": {
        "ClusterId": "patients",
        "Match": { "Path": "/api/v1/patients/{**catch-all}" }
      },
      "appointments": {
        "ClusterId": "appointments",
        "Match": { "Path": "/api/v1/appointments/{**catch-all}" }
      },
      "clinical": {
        "ClusterId": "clinical",
        "Match": { "Path": "/api/v1/encounters/{**catch-all}" }
      },
      "lab": {
        "ClusterId": "lab",
        "Match": { "Path": "/api/v1/lab-orders/{**catch-all}" }
      },
      "lab-critical-alerts": {
        "ClusterId": "lab",
        "Match": { "Path": "/api/v1/critical-alerts/{**catch-all}" }
      },
      "lab-critical-alert-rules": {
        "ClusterId": "lab",
        "Match": { "Path": "/api/v1/critical-alert-rules/{**catch-all}" }
      },
      "billing": {
        "ClusterId": "billing",
        "Match": { "Path": "/api/v1/invoices/{**catch-all}" }
      },
      "pharmacy-medications": {
        "ClusterId": "pharmacy",
        "Match": { "Path": "/api/v1/medications/{**catch-all}" }
      },
      "pharmacy-prescriptions": {
        "ClusterId": "pharmacy",
        "Match": { "Path": "/api/v1/prescriptions/{**catch-all}" }
      },
      "lab-bff": {
        "ClusterId": "lab-bff",
        "Match": { "Path": "/api/v1/bff/lab/{**catch-all}" }
      },
      "billing-bff": {
        "ClusterId": "billing-bff",
        "Match": { "Path": "/api/v1/bff/billing/{**catch-all}" }
      },
      "dashboard-bff": {
        "ClusterId": "dashboard-bff",
        "Match": { "Path": "/api/v1/bff/dashboard/{**catch-all}" }
      },
      "admin": {
        "ClusterId": "identity",
        "Match": { "Path": "/api/v1/admin/{**catch-all}" }
      },
      "settings": {
        "ClusterId": "identity",
        "Match": { "Path": "/api/v1/settings/{**catch-all}" }
      },
      "audit-logs": {
        "ClusterId": "identity",
        "Match": { "Path": "/api/v1/audit-logs/{**catch-all}" }
      },
      "audit-events": {
        "ClusterId": "identity",
        "Match": { "Path": "/api/v1/audit/{**catch-all}" }
      },
      "dashboard": {
        "ClusterId": "clinical",
        "Match": { "Path": "/api/v1/dashboard/{**catch-all}" }
      },
      "errors": {
        "ClusterId": "identity",
        "Match": { "Path": "/api/v1/errors/{**catch-all}" }
      },
      "oidc-connect": {
        "ClusterId": "identity",
        "Match": { "Path": "/connect/{**catch-all}" }
      },
      "oidc-discovery": {
        "ClusterId": "identity",
        "Match": { "Path": "/.well-known/{**catch-all}" }
      },
      "oidc-account": {
        "ClusterId": "identity",
        "Match": { "Path": "/Account/{**catch-all}" }
      }
    },
    "Clusters": {
      "identity": {
        "Destinations": {
          "identity/dest": { "Address": "http://identityservice:5001/" }
        }
      },
      "patients": {
        "Destinations": {
          "patients/dest": { "Address": "http://patientservice:5002/" }
        }
      },
      "appointments": {
        "Destinations": {
          "appointments/dest": { "Address": "http://appointmentservice:5003/" }
        }
      },
      "clinical": {
        "Destinations": {
          "clinical/dest": { "Address": "http://clinicalservice:5004/" }
        }
      },
      "lab": {
        "Destinations": {
          "lab/dest": { "Address": "http://labservice:5010/" }
        }
      },
      "billing": {
        "Destinations": {
          "billing/dest": { "Address": "http://billingservice:5020/" }
        }
      },
      "pharmacy": {
        "Destinations": {
          "pharmacy/dest": { "Address": "http://pharmacyservice:5030/" }
        }
      },
      "lab-bff": {
        "Destinations": {
          "lab-bff/dest": { "Address": "http://lab-bff.his-hope.svc:5300/" }
        }
      },
      "billing-bff": {
        "Destinations": {
          "billing-bff/dest": { "Address": "http://billing-bff.his-hope.svc:5400/" }
        }
      },
      "dashboard-bff": {
        "Destinations": {
          "dashboard-bff/dest": { "Address": "http://dashboard-bff.his-hope.svc:5600/" }
        }
      }
    }
  },
  "CORS": {
    "AllowedOrigins": "http://localhost:4200,http://localhost:4201,http://localhost:8081,http://localhost:8082,http://frontend:8080,https://app.his-hope.internal"
  },
  "Certificates": {
    "Path": "",
    "Password": ""
  },
  "RateLimiting": {
    "MaxRequestsPerIp": 1000,
    "MaxRequestsPerUser": 2000,
    "WindowMinutes": 1
  },
  "ConnectionStrings": {
    "IdempotencyDb": "Host=localhost;Port=26257;Database=his_hope_idempotency;Username=root;Password=;"
  }
}
