{
  "Serilog": {
    "MinimumLevel": { "Default": "Information" },
    "WriteTo": [{ "Name": "Console" }]
  },
  "ReverseProxy": {
    "Routes": {
      "identity": {
        "ClusterId": "identity",
        "Match": { "Path": "/api/v1/auth/{**catch-all}" }
      },
      "patients-encounters": {
        "ClusterId": "clinical",
        "Match": { "Path": "/api/v1/patients/{id}/encounters/{**remainder}" }
      },
      "patients-appointments": {
        "ClusterId": "appointments",
        "Match": { "Path": "/api/v1/patients/{id}/appointments/{**remainder}" }
      },
      "patients-prescriptions": {
        "ClusterId": "pharmacy",
        "Match": { "Path": "/api/v1/patients/{id}/prescriptions/{**remainder}" }
      },
      "patients-lab-orders": {
        "ClusterId": "lab",
        "Match": { "Path": "/api/v1/patients/{id}/lab-orders/{**remainder}" }
      },
      "patients-invoices": {
        "ClusterId": "billing",
        "Match": { "Path": "/api/v1/patients/{id}/invoices/{**remainder}" }
      },
      "patients": {
        "ClusterId": "patients",
        "Match": { "Path": "/api/v1/patients/{**catch-all}" }
      },
      "appointments": {
        "ClusterId": "appointments",
        "Match": { "Path": "/api/v1/appointments/{**catch-all}" }
      },
      "clinical": {
        "ClusterId": "clinical",
        "Match": { "Path": "/api/v1/encounters/{**catch-all}" }
      },
      "lab": {
        "ClusterId": "lab",
        "Match": { "Path": "/api/v1/lab-orders/{**catch-all}" }
      },
      "billing": {
        "ClusterId": "billing",
        "Match": { "Path": "/api/v1/invoices/{**catch-all}" }
      },
      "pharmacy-medications": {
        "ClusterId": "pharmacy",
        "Match": { "Path": "/api/v1/medications/{**catch-all}" }
      },
      "pharmacy-prescriptions": {
        "ClusterId": "pharmacy",
        "Match": { "Path": "/api/v1/prescriptions/{**catch-all}" }
      },
      "dashboard": {
        "ClusterId": "clinical",
        "Match": { "Path": "/api/v1/dashboard/{**catch-all}" }
      },
      "errors": {
        "ClusterId": "clinical",
        "Match": { "Path": "/api/v1/errors/{**catch-all}" }
      },
      "admin": {
        "ClusterId": "identity",
        "Match": { "Path": "/api/v1/admin/{**catch-all}" }
      }
    },
    "Clusters": {
      "identity": {
        "Destinations": {
          "identity/dest": { "Address": "http://identityservice:5001/" }
        }
      },
      "patients": {
        "Destinations": {
          "patients/dest": { "Address": "http://patientservice:5002/" }
        }
      },
      "appointments": {
        "Destinations": {
          "appointments/dest": { "Address": "http://appointmentservice:5003/" }
        }
      },
      "clinical": {
        "Destinations": {
          "clinical/dest": { "Address": "http://clinicalservice:5004/" }
        }
      },
      "lab": {
        "Destinations": {
          "lab/dest": { "Address": "http://labservice:5010/" }
        }
      },
      "billing": {
        "Destinations": {
          "billing/dest": { "Address": "http://billingservice:5020/" }
        }
      },
      "pharmacy": {
        "Destinations": {
          "pharmacy/dest": { "Address": "http://pharmacyservice:5030/" }
        }
      }
    }
  },
  "CORS": {
    "AllowedOrigins": "http://localhost:4200,http://localhost:8081,http://frontend:8080,https://app.his-hope.internal"
  },
  "Certificates": {
    "Path": "",
    "Password": ""
  },
  "RateLimiting": {
    "MaxRequestsPerIp": 1000,
    "MaxRequestsPerUser": 2000,
    "WindowMinutes": 1
  }
}
