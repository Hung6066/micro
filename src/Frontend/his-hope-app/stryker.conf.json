{
  "$schema": "./node_modules/@stryker-mutator/core/schema/stryker-schema.json",
  "packageManager": "npm",
  "reporters": ["html", "progress", "clear-text"],
  "testRunner": "karma",
  "karma": {
    "configFile": "karma.conf.js",
    "projectType": "angular-cli"
  },
  "coverageAnalysis": "perTest",
  "thresholds": {
    "high": 75,
    "low": 65,
    "break": 55
  },
  "mutate": [
    "src/app/**/*.ts",
    "!src/app/**/*.spec.ts",
    "!src/app/**/*.module.ts",
    "!src/app/core/models/**",
    "!src/app/core/services/mock/**",
    "!src/app/**/*.model.ts"
  ],
  "timeoutMs": 30000
}
