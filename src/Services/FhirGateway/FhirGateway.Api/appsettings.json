{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "Elasticsearch",
        "Args": {
          "nodeUris": "http://localhost:9200",
          "indexFormat": "his-hope-fhir-gateway-{0:yyyy.MM}"
        }
      }
    ]
  },
  "AllowedHosts": "*",
  "Cors": {
    "Origins": ["http://localhost:4200"]
  }
}
