{
  "ConnectionStrings": {
    "ClinicalDb": "Host=localhost;Port=5433;Database=clinicaldb;Username=postgres;Password=${DB_PASSWORD}"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "Elasticsearch",
        "Args": {
          "nodeUris": "http://localhost:9200",
          "indexFormat": "his-hope-clinical-{0:yyyy.MM}"
        }
      }
    ]
  },
  "AllowedHosts": "*",
  "RateLimiting": {
    "MaxRequestsPerIp": 1000,
    "MaxRequestsPerUser": 2000,
    "WindowMinutes": 1
  }
}
