{
  "ConnectionStrings": {
    "AppointmentDb": "Host=localhost;Port=5433;Database=appointmentdb;Username=postgres;Password=${DB_PASSWORD}"
  },
  "GrpcServices": {
    "PatientService": "http://localhost:5013"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" }
    ]
  },
  "AllowedHosts": "*"
}
