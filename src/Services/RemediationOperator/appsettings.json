{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning",
        "KubernetesClient": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "/var/log/remediation-operator/log-.json",
          "rollingInterval": "Day",
          "formatter": "Serilog.Formatting.Json.JsonFormatter"
        }
      }
    ]
  },
  "RemediationOperator": {
    "WebhookPort": 8080,
    "MetricsPort": 9090,
    "Namespace": "his-hope",
    "CooldownDefaultMinutes": 5,
    "MaxConcurrentActions": 5,
    "AlertmanagerSourceIpWhitelist": [],
    "DryRun": false
  }
}
