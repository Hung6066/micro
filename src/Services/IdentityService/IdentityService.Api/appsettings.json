{
  "ConnectionStrings": {
    "IdentityDb": "Host=localhost;Port=5433;Database=identitydb;Username=postgres;Password=${DB_PASSWORD}"
  },
  "Jwt": {
    "Issuer": "His.Hope.IdentityService",
    "Audience": "His.Hope",
    "Key": "${JWT_SIGNING_KEY}",
    "RsaPublicKeyPath": "${JWT_RSA_PUBLIC_KEY_PATH:-Certificates/jwt-public-key.pem}",
    "RsaPrivateKeyPath": "${JWT_RSA_PRIVATE_KEY_PATH:-Certificates/jwt-private-key.pem}"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "Elasticsearch",
        "Args": {
          "nodeUris": "http://elasticsearch:9200",
          "indexFormat": "his-hope-logs-{0:yyyy.MM.dd}",
          "autoRegisterTemplate": true,
          "typeName": "logevent",
          "batchPostingLimit": 50,
          "inlineFields": true
        }
      }
    ],
    "Enrich": [
      { "Name": "WithProperty", "Args": { "name": "service", "value": "identity-service" } }
    ]
  },
  "AllowedHosts": "*"
}
