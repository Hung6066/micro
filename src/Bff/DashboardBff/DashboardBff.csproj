<Project Sdk="Microsoft.NET.Sdk.Web">
  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <RootNamespace>DashboardBff</RootNamespace>
  </PropertyGroup>
  <ItemGroup>
    <ProjectReference Include="..\His.Hope.Bff.Core\His.Hope.Bff.Core.csproj" />
    <Protobuf Include="..\..\Shared\Protos\patient.proto" GrpcServices="Client" Link="Protos\patient.proto" />
    <Protobuf Include="..\..\Shared\Protos\clinical.proto" GrpcServices="Client" Link="Protos\clinical.proto" />
    <Protobuf Include="..\..\Shared\Protos\lab.proto" GrpcServices="Client" Link="Protos\lab.proto" />
    <Protobuf Include="..\..\Shared\Protos\billing.proto" GrpcServices="Client" Link="Protos\billing.proto" />
    <Protobuf Include="..\..\Shared\Protos\pharmacy.proto" GrpcServices="Client" Link="Protos\pharmacy.proto" />
    <Protobuf Include="..\..\Shared\Protos\appointment.proto" GrpcServices="Client" Link="Protos\appointment.proto" />
  </ItemGroup>
  <ItemGroup>
    <PackageReference Include="Grpc.Net.ClientFactory" Version="2.60.0" />
    <PackageReference Include="Grpc.Tools" Version="2.62.0">
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers</IncludeAssets>
    </PackageReference>
    <PackageReference Include="Google.Protobuf" Version="3.26.1" />
  </ItemGroup>
  <ItemGroup>
    <InternalsVisibleTo Include="DashboardBff.IntegrationTests" />
  </ItemGroup>
</Project>
