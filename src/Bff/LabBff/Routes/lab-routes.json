{
  "ReverseProxy": {
    "Routes": {
      "lab-search": {
        "ClusterId": "lab-service",
        "Match": { "Path": "/api/v1/lab-orders/search", "Methods": ["GET"] }
      },
      "lab-get": {
        "ClusterId": "lab-service",
        "Match": { "Path": "/api/v1/lab-orders/{id}", "Methods": ["GET"] }
      },
      "lab-create": {
        "ClusterId": "lab-service",
        "Match": { "Path": "/api/v1/lab-orders", "Methods": ["POST"] }
      },
      "lab-submit": {
        "ClusterId": "lab-service",
        "Match": { "Path": "/api/v1/lab-orders/{id}/submit", "Methods": ["POST"] }
      },
      "lab-collect": {
        "ClusterId": "lab-service",
        "Match": { "Path": "/api/v1/lab-orders/{id}/collect", "Methods": ["POST"] }
      },
      "lab-result": {
        "ClusterId": "lab-service",
        "Match": { "Path": "/api/v1/lab-orders/{id}/result", "Methods": ["POST"] }
      },
      "lab-cancel": {
        "ClusterId": "lab-service",
        "Match": { "Path": "/api/v1/lab-orders/{id}/cancel", "Methods": ["POST"] }
      },
      "critical-alert-list": {
        "ClusterId": "lab-service",
        "Match": { "Path": "/api/v1/critical-alerts", "Methods": ["GET", "POST"] }
      },
      "critical-alert-acknowledge": {
        "ClusterId": "lab-service",
        "Match": { "Path": "/api/v1/critical-alerts/{id}/acknowledge", "Methods": ["POST"] }
      },
      "critical-alert-resolve": {
        "ClusterId": "lab-service",
        "Match": { "Path": "/api/v1/critical-alerts/{id}/resolve", "Methods": ["POST"] }
      },
      "critical-alert-rules-list": {
        "ClusterId": "lab-service",
        "Match": { "Path": "/api/v1/critical-alert-rules", "Methods": ["GET", "POST"] }
      },
      "critical-alert-rules-item": {
        "ClusterId": "lab-service",
        "Match": { "Path": "/api/v1/critical-alert-rules/{id}", "Methods": ["GET", "PUT", "DELETE"] }
      }
    },
    "Clusters": {
      "lab-service": {
        "Destinations": {
          "lab": { "Address": "http://labservice:5010/" }
        }
      }
    }
  }
}
