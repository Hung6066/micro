{
  "title": "Agent Harness — Pipeline Operations",
  "version": 1,
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {
    "refresh_intervals": ["5s", "10s", "30s", "1m", "5m", "15m", "30m", "1h"]
  },
  "templating": {
    "list": [
      {
        "name": "DS_PROMETHEUS",
        "type": "datasource",
        "query": "prometheus",
        "current": { "dsType": "prometheus" }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Pipeline Execution Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 0 },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        {
          "expr": "rate(harness_pipeline_starts_total[5m])",
          "legendFormat": "Starts"
        },
        {
          "expr": "rate(harness_pipeline_completions_total[5m])",
          "legendFormat": "Completions"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "rps",
          "decimals": 2
        },
        "overrides": []
      }
    },
    {
      "id": 2,
      "title": "Pipeline Success Rate",
      "type": "stat",
      "gridPos": { "h": 8, "w": 3, "x": 6, "y": 0 },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        {
          "expr": "rate(harness_pipeline_completions_total[5m]) / rate(harness_pipeline_starts_total[5m]) * 100",
          "legendFormat": "Success Rate"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 90 },
              { "color": "green", "value": 95 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 3,
      "title": "Active Pipelines",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 3, "x": 9, "y": 0 },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        {
          "expr": "harness_active_pipelines",
          "legendFormat": "Active"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 8 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 4,
      "title": "Agent Dispatch Latency (p50 / p95 / p99)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(harness_agent_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(harness_agent_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(harness_agent_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p99"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "decimals": 2
        },
        "overrides": []
      }
    },
    {
      "id": 5,
      "title": "Circuit Breaker Status",
      "type": "stat",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 8 },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        {
          "expr": "sum(harness_active_pipelines{circuit_state=\"open\"}) OR vector(0)",
          "legendFormat": "Open"
        },
        {
          "expr": "sum(harness_active_pipelines{circuit_state=\"half-open\"}) OR vector(0)",
          "legendFormat": "Half-Open"
        },
        {
          "expr": "sum(harness_active_pipelines{circuit_state=\"closed\"}) OR vector(0)",
          "legendFormat": "Closed"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none"
        },
        "overrides": []
      }
    },
    {
      "id": 6,
      "title": "Pipeline Duration",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 8 },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(harness_pipeline_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(harness_pipeline_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(harness_pipeline_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p99"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "decimals": 1
        },
        "overrides": []
      }
    },
    {
      "id": 7,
      "title": "Loop Engineer — Fix Success Rate",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 8 },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        {
          "expr": "rate(harness_loop_engineer_fixes_total{outcome=\"auto_fixed\"}[5m]) / rate(harness_loop_engineer_fixes_total[5m]) * 100",
          "legendFormat": "Fix Rate"
        },
        {
          "expr": "rate(harness_loop_engineer_fixes_total{outcome=\"escalated\"}[5m])",
          "legendFormat": "Escalations"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 1
        },
        "overrides": []
      }
    },
    {
      "id": 8,
      "title": "Backpressure Rejections",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 8 },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        {
          "expr": "rate(harness_backpressure_rejections_total[5m])",
          "legendFormat": "Rejections/s"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "rps",
          "decimals": 2
        },
        "overrides": []
      }
    },
    {
      "id": 9,
      "title": "Agent Dispatch Count by Agent",
      "type": "bargauge",
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 14 },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        {
          "expr": "topk(10, sum(increase(harness_agent_dispatches_total[24h])) by (agent))",
          "legendFormat": "{{agent}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none"
        },
        "overrides": []
      }
    },
    {
      "id": 10,
      "title": "Event Bus — Published Events",
      "type": "timeseries",
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 14 },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        {
          "expr": "rate(harness_events_published_total[5m])",
          "legendFormat": "Events/s"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "rps",
          "decimals": 2
        },
        "overrides": []
      }
    }
  ]
}
